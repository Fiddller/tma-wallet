# TestJetton master contract (testnet)
# https://github.com/seniorGarin/test-master
VITE_JETTON_MASTER=kQD8IpAw9lq0c13mg7_iRRMv1cwMEAC_F2tDlFAJDqEVxb5x

# Decimals жетона
VITE_JETTON_DECIMALS=9

# Toncenter API (для get-методов через runGetMethod)
VITE_TONCENTER_ENDPOINT=https://testnet.toncenter.com/api/v2

# TonClient4 endpoint (для ContractProvider)
VITE_TONCLIENT_ENDPOINT=https://testnet-v4.tonhubapi.com

# === ОБЯЗАТЕЛЬНО ===
# Telegram bot username (без @) — тот которому задал Menu Button в @BotFather
VITE_BOT_USERNAME=your_bot_username

# Название TMA приложения — short name из /newapp в @BotFather
# (используется в диплинке t.me/<bot>/<app>?startapp=...)
VITE_APP_NAME=your_app_name
